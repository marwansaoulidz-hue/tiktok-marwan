# Domaine (laisser localhost pour test local)
DOMAIN=localhost

# PostgreSQL
POSTGRES_USER=socialapp
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=socialapp

# Redis
REDIS_URL=redis://redis:6379

# MinIO (stockage vidéos)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=videos
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=7d

# Admin initial (créé au premier démarrage)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change_me_admin_password
ADMIN_USERNAME=admin

# Giphy (GIF dans la messagerie) - https://developers.giphy.com/
GIPHY_API_KEY=

# Limites stockage (Go)
VIDEO_STORAGE_LIMIT_GB=150
PLATFORM_STORAGE_LIMIT_GB=180
MAX_VIDEOS_PER_USER=50
MAX_VIDEO_DURATION_SEC=45
MAX_UPLOAD_SIZE_MB=100

# URLs internes Docker
DATABASE_URL=postgresql://socialapp:change_me_strong_password@postgres:5432/socialapp
API_URL=http://api:3001
NEXT_PUBLIC_API_URL=http://localhost/api
